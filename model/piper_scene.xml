<mujoco model="piper_scene">
  <!--
    Scene file for the AgileX Piper 6-DOF robot arm.

    IMPORTANT — two usage patterns depending on your piper.xml source:

    Pattern A (MuJoCo Menagerie / fragment style):
      piper.xml contains only element subtrees with no <mujoco> root.
      The <include> below merges its worldbody/actuator/sensor sections here.
      This is the recommended approach for scene composition.

    Pattern B (standalone MJCF):
      If your piper.xml is a self-contained model (has its own <mujoco> root),
      skip this file and load piper.xml directly:
        model_path: asset/piper/piper.xml
      Then add ground/lighting via the piper.xml <worldbody> if desired.
  -->

  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <!-- Include the Piper robot model fragment (Pattern A).
       Expected to define: <worldbody>, <actuator>, optionally <sensor>, <contact>. -->
  <include file="../asset/piper/piper.xml"/>

  <worldbody>
    <light name="sun" pos="0 0 4" dir="0 0 -1" directional="true"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" castshadow="true"/>
    <light name="fill" pos="2 -2 2" directional="false"
           diffuse="0.3 0.3 0.3" specular="0 0 0" castshadow="false"/>
    <geom name="floor" type="plane" size="3 3 0.1" material="groundplane" condim="3"/>
  </worldbody>

</mujoco>
